<!-- Main Content Canvas -->
<main class="pt-10 pb-24 px-4 max-w-lg mx-auto">
<!-- Summary Dashboard Card -->
<section class="mb-unit-6 bg-primary-container p-unit-4 rounded-xl text-white shadow-sm overflow-hidden relative">
<div class="relative z-10">
<p class="font-label-caps text-on-primary-container text-xs mb-1">ADMINISTRACIÓN</p>
<h2 class="font-h2 text-h2 mb-4">Postulantes Madrigal 2</h2>
<div class="flex items-center gap-2">
  <span class="material-symbols-outlined text-sm" data-icon="group">group</span>
  <span class="font-body-sm text-on-primary-container"><%= data.length %> Candidatos activos</span>
</div>
</div>
<div class="absolute -right-6 -bottom-6 opacity-10">
  <span class="material-symbols-outlined text-[120px]" data-icon="apartment">apartment</span>
</div>
</section>
<!-- Applicants List -->
<div class="space-y-4">
  <!-- BackEnd Data -->
  
  <% data.forEach(post => { %>
    
    <!-- Applicant Card 1 -->
    <div class="bg-white border border-[#E2E8F0] p-unit-4 rounded-xl flex flex-col gap-4">
      <div class="flex justify-between items-start">
        <div class="flex gap-3">
          <div class="w-12 h-12 rounded-full bg-surface-container flex items-center justify-center overflow-hidden">
            <img class="w-full h-full object-cover" alt="no se que pasa" src="/images/<%= post.pic %>"/>
          </div>
          <div>
            <h3 class="font-h3 text-h3 text-primary"><%= post.nombre %></h3>
            <div class="flex items-center gap-1 text-on-secondary-container">
              <span class="material-symbols-outlined text-xs" data-icon="calendar_today">calendar_today</span>
              <span class="font-body-sm text-xs"><%= post.cel %></span>
            </div>
          </div>
        </div>
        <span class="bg-secondary-container text-on-secondary-fixed-variant px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wider"><%= post.refiere %></span>
      </div>
      <div class="flex gap-2 w-full">
        <% if (!post.hv) { %>
       <p class="flex-1 flex items-center justify-center gap-2 bg-[#FF2400] text-white font-button text-button py-2.5 rounded-lg hover:opacity-90 transition-opacity">AUN NO SE HA RECIBIDO HOJA DE VIDA</p>
       <% } else { %>
        <a href="/docs/<%= post.hv %>" target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-2 bg-[#1B2B48] text-white font-button text-button py-2.5 rounded-lg hover:opacity-90 transition-opacity">
          <button >
            <span class="material-symbols-outlined text-sm" data-icon="visibility">visibility</span>
            Ver Hoja de Vida
          </button>
        </a>
        <button class="flex items-center justify-center px-4 border border-[#1B2B48] text-[#1B2B48] font-button text-button rounded-lg hover:bg-surface-container-low transition-colors">
          <span class="material-symbols-outlined text-sm" data-icon="download">download</span>
        </button>
          <% } %>
      </div>
    </div>
    <% })  %>

</div>
</main>
